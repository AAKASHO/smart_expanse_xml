<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
<ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="16dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_insights"
                app:tint="@color/primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:text="Smart Expense"
                android:textColor="@color/primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/iv_profile"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:bindingRadius="20dp"
                app:bindingStartColor="@{@color/surface_container}"
                android:clipToOutline="true"
                android:padding="8dp"
                android:src="@drawable/ic_settings"
                app:tint="@color/primary" />
        </LinearLayout>

        <!-- Hero Spending Card -->
        <LinearLayout
            android:id="@+id/hero_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:bindingRadius="24dp"
            app:bindingStartColor="@{@color/primary}"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.15"
                android:text="@string/monthly_spending"
                android:textAllCaps="true"
                android:textColor="#B3FFFFFF"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="bottom"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_spending_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="₹0"
                    android:textColor="@android:color/white"
                    android:textSize="36sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_budget_divider"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="4dp"
                    android:text=" / ₹30,000"
                    android:textColor="#99FFFFFF"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Budget Usage Badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:bindingRadius="12dp"
                app:bindingStartColor="@{@color/surface_container}"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp">

                <TextView
                    android:id="@+id/tv_budget_percentage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0% of budget used"
                    android:textColor="@color/on_surface"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progress_budget"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginTop="16dp"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/bg_progress_bar" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_start_date"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Started this month"
                    android:textColor="#99FFFFFF"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tv_remaining"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹30,000 Remaining"
                    android:textColor="#99FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- AI Insights Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:text="@string/ai_insights"
                android:textColor="@color/primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_view_all_insights"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/view_all"
                android:textColor="@color/secondary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Insight Cards Container -->
        <LinearLayout
            android:id="@+id/insights_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <!-- Insight 1: Budget Warning -->
            <LinearLayout
                android:id="@+id/card_budget_warning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:bindingRadius="16dp"
                app:bindingStartColor="@{@android:color/white}"
                android:orientation="vertical"
                android:padding="20dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        app:bindingRadius="12dp"
                        app:bindingStartColor="@{@color/error_container}"
                        android:padding="6dp"
                        android:src="@drawable/ic_notification"
                        app:tint="@color/error" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/critical"
                        android:textAllCaps="true"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/budget_warning"
                    android:textColor="@color/on_surface"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_budget_warning_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text=""
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Insight 2: Trend Detection -->
            <LinearLayout
                android:id="@+id/card_trend"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:bindingRadius="16dp"
                app:bindingStartColor="@{@android:color/white}"
                android:orientation="vertical"
                android:padding="20dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        app:bindingRadius="12dp"
                        app:bindingStartColor="@{@color/primary_container}"
                        android:padding="6dp"
                        android:src="@drawable/ic_insights"
                        app:tint="@android:color/white" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pattern"
                        android:textAllCaps="true"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/trend_detection"
                    android:textColor="@color/on_surface"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_trend_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text=""
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Insight 3: Top Category -->
            <LinearLayout
                android:id="@+id/card_top_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:bindingRadius="16dp"
                app:bindingStartColor="@{@android:color/white}"
                android:orientation="vertical"
                android:padding="20dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        app:bindingRadius="12dp"
                        app:bindingStartColor="@{@color/secondary_container}"
                        android:padding="6dp"
                        android:src="@drawable/ic_home"
                        app:tint="@color/on_secondary_container" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/top_spend"
                        android:textAllCaps="true"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/top_category"
                    android:textColor="@color/on_surface"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_top_category_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text=""
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Empty State -->
            <TextView
                android:id="@+id/tv_no_insights"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:bindingRadius="16dp"
                app:bindingStartColor="@{@android:color/white}"
                android:gravity="center"
                android:padding="24dp"
                android:text="Add some expenses to see AI-generated insights here!"
                android:textColor="@color/on_surface_variant"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Recent Activity Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/recent_activity"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/recent_transactions_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:bindingRadius="16dp"
            app:bindingStartColor="@{@android:color/white}"
            android:orientation="vertical"
            android:padding="4dp" />

        <!-- Empty state for recent activity -->
        <TextView
            android:id="@+id/tv_no_transactions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:bindingRadius="16dp"
            app:bindingStartColor="@{@android:color/white}"
            android:gravity="center"
            android:padding="32dp"
            android:text="@string/no_transactions"
            android:textColor="@color/on_surface_variant"
            android:textSize="14sp" />

        <!-- View All Button -->
        <TextView
            android:id="@+id/btn_view_all"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:bindingRadius="16dp"
            app:bindingStartColor="@{@android:color/white}"
            android:gravity="center"
            android:padding="16dp"
            android:text="@string/view_all_transactions"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
</layout>
